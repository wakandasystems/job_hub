APP_NAME="Job Hub"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://jobhunter.wakandasystems.com
APP_KEY=
LOG_CHANNEL=daily

BROADCAST_DRIVER=log
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SESSION_HTTP_ONLY=true
SESSION_SECURE_COOKIE=true
ENABLE_HTTP_SECURITY_HEADERS=true

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE="job_hub"
DB_USERNAME="job_hub_user"
DB_PASSWORD="change_me"
DB_STRICT=false

ADMIN_DIR=admin
CMS_ENABLE_INSTALLER=false

# Uncomment if your reverse proxy or SSL setup requires it.
# FORCE_SCHEMA=https
# FORCE_ROOT_URL=https://jobhunter.wakandasystems.com
